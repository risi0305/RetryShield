PORT=4000

# Shared code gating the frontend demo — not real auth, just a lightweight
# gate to keep a public link from being casually stumbled onto.
ACCESS_CODE=retryshield2026

# Firebase Admin SDK service account credentials
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the literal \n escapes in the private key when pasting it into .env
FIREBASE_PRIVATE_KEY=

# AI provider key — only ever used server-side
AI_API_KEY=
# Which provider AI_API_KEY belongs to: "openai" (default) or "gemini"
AI_PROVIDER=gemini
